# ==============================================
# GEZMA Agent — Environment Variables
# ==============================================
# Copy this file to .env.local and fill in values
# Required vars are marked with [REQUIRED]
# Optional vars have sensible defaults

# --- Database ---
DB_PASSWORD=your_secure_password_here                          # [REQUIRED] PostgreSQL password
DATABASE_URL=postgresql://gezma_admin:${DB_PASSWORD}@db:5432/gezma_agent  # [REQUIRED] Full connection string

# --- Authentication ---
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_long     # [REQUIRED] Min 32 chars, used for agent + pilgrim tokens
JWT_EXPIRES_IN=7d                                              # Token expiry (default: 7d)

# --- App URLs ---
APP_URL=https://your-domain.com                                # [REQUIRED] Server-side base URL
NEXT_PUBLIC_APP_URL=https://your-domain.com                    # [REQUIRED] Client-side base URL
NEXT_PUBLIC_APP_NAME=GEZMA Agent                               # App display name (default: GEZMA Agent)

# --- SMTP / Email ---
SMTP_HOST=smtp.gmail.com                                       # SMTP server (default: smtp.gmail.com)
SMTP_PORT=587                                                  # SMTP port (default: 587)
SMTP_USER=your_email@gmail.com                                 # SMTP username
SMTP_PASS=your_app_password_here                               # SMTP password / app password
SMTP_FROM=your_email@gmail.com                                 # Sender email address

# --- AI Assistant ---
GEMINI_API_KEY=your_gemini_api_key_here                        # Google Gemini 2.0 Flash API key

# --- File Storage ---
STORAGE_DRIVER=local                                           # "local" or "s3" (default: local)
# S3/MinIO config (required when STORAGE_DRIVER=s3):
# S3_BUCKET=gezma-uploads
# S3_REGION=us-east-1
# S3_ENDPOINT=https://minio.your-domain.com                   # For MinIO, omit for AWS S3
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key

# --- Cron Jobs ---
CRON_ENABLED=true                                              # Enable scheduled jobs (default: true)

# --- Security ---
TOTP_ENCRYPTION_KEY=your_32_char_encryption_key_here           # AES-256 key for 2FA TOTP secrets
NODE_ENV=production                                            # "development", "production", or "test"
