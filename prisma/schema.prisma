generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Agency {
  id              String   @id @default(uuid())
  name            String   // Company brand name
  legalName       String   // PT. ...
  tagline         String?
  description     String?

  // PPIU Info
  ppiuNumber      String?  @unique
  ppiuIssueDate   DateTime?
  ppiuExpiryDate  DateTime?
  ppiuStatus      String   @default("pending") // pending, active, expiring, expired

  // Contact
  email           String   @unique
  phone           String
  whatsapp        String?
  website         String?

  // Address
  address         String?
  city            String?
  province        String?
  postalCode      String?

  // Branding
  primaryColor    String   @default("#F60000")
  logoUrl         String?

  // Verification
  verificationCode String  @unique @default(uuid())
  isVerified       Boolean @default(false)

  // Settings
  currency        String   @default("IDR")
  timezone        String   @default("Asia/Jakarta")

  // White-label Branding
  secondaryColor  String?
  faviconUrl      String?
  logoLightUrl    String?
  logoDarkUrl     String?
  appTitle        String?

  // Gamification
  totalPoints     Int      @default(0)

  // Public profile
  slug            String?  @unique

  // Custom Domain (white-label)
  customDomain    String?  @unique

  // Relations
  users           User[]
  pilgrims        Pilgrim[]
  packages        Package[]
  trips           Trip[]
  activityLogs    ActivityLog[]
  manasikLessons  ManasikLesson[]
  doaPrayers      DoaPrayer[]
  leaderboard     AgencyLeaderboard[]
  pointEvents     PointEvent[]
  certificates    BlockchainCertificate[]
  tasks           AgencyTask[]
  emailTemplates  EmailTemplate[]
  waitingList     WaitingList[]
  pilgrimNotes    PilgrimNote[]
  pilgrimPhotos   PilgrimPhoto[]
  pilgrimTestimonials PilgrimTestimonial[]
  referrals       Referral[]
  notifications   Notification[]
  scheduledReports ScheduledReport[]
  roommatePreferences RoommatePreference[]
  tradeProducts   TradeProduct[]
  tradeInquiries  TradeInquiry[]
  gezmaPayWallets GezmaPayWallet[]
  umrahSavings    UmrahSavings[]
  payLaterApps    PayLaterApplication[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ppiuStatus, ppiuExpiryDate])
  @@map("agencies")
}

model User {
  id              String   @id @default(uuid())

  // Personal Info
  name            String
  email           String   @unique
  password        String   // bcrypt hashed
  phone           String?
  position        String?  // e.g., "Direktur", "Admin Operasional"
  avatarUrl       String?

  // Role
  role            String   @default("admin") // owner, admin, staff, marketing

  // Granular Permissions (JSON override per-user)
  permissions     Json?

  // Status
  isActive        Boolean  @default(true)
  isVerified      Boolean  @default(false)
  verificationCode String? @unique
  verificationExpiry DateTime?

  // 2FA / TOTP
  totpSecret      String?
  totpEnabled     Boolean  @default(false)

  // Onboarding
  onboardingCompleted Boolean @default(false)

  // Gamification
  totalPoints     Int      @default(0)
  level           Int      @default(1)

  // Agency relation
  agencyId        String
  agency          Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // Session tracking
  lastLoginAt     DateTime?

  // Soft delete
  deletedAt       DateTime?

  // Relations
  activityLogs    ActivityLog[]
  notificationPrefs NotificationPreference?
  pointEvents     PointEvent[]
  badges          UserBadge[]
  courseProgress   AcademyCourseProgress[]
  loginHistory    LoginHistory[]
  notifications   Notification[]
  quizAttempts    AcademyQuizAttempt[]
  courseReviews   AcademyCourseReview[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([agencyId])
  @@index([deletedAt])
  @@map("users")
}

model Pilgrim {
  id                String   @id @default(uuid())

  // Personal Info
  nik               String
  name              String
  gender            String   // male, female
  birthPlace        String
  birthDate         String   // ISO date string
  address           String
  city              String
  province          String
  postalCode        String?

  // Contact
  phone             String
  email             String
  whatsapp          String?

  // Emergency Contact (JSON)
  emergencyContact  Json     // { name, phone, relation }

  // Checklist (JSON)
  checklist         Json     @default("{}")

  // Booking
  bookingCode       String?

  // Verification
  verificationCode  String?  @unique

  // Status & Assignment
  status            String   @default("lead") // lead, dp, lunas, dokumen, visa, ready, departed, completed
  tripId            String?
  roomNumber        String?
  roomType          String?  // single, double, triple, quad

  // Cached payment totals
  totalPaid         Float    @default(0)
  remainingBalance  Float    @default(0)

  // Notes
  notes             String?

  // Metadata
  createdBy         String?

  // Soft delete
  deletedAt         DateTime?

  // Multi-tenant
  agencyId          String
  agency            Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // Relations
  documents         PilgrimDocument[]
  payments          PaymentRecord[]
  manasikProgress   PilgrimManasikProgress[]
  doaFavorites      PilgrimDoaFavorite[]
  certificates      BlockchainCertificate[]
  pointEvents       PilgrimPointEvent[]
  badges            PilgrimBadge[]
  pilgrimNotes      PilgrimNote[]
  photos            PilgrimPhoto[]
  testimonials      PilgrimTestimonial[]
  referralsMade     Referral[] @relation("referrer")
  referralReceived  Referral?  @relation("referred")
  roommatePreference RoommatePreference?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([agencyId])
  @@index([status])
  @@index([deletedAt])
  @@unique([nik, agencyId])
  @@unique([agencyId, bookingCode])
  @@map("pilgrims")
}

model PilgrimDocument {
  id          String    @id @default(uuid())
  type        String    // ktp, passport, photo, visa, health_cert, book_nikah
  status      String    @default("missing") // missing, uploaded, verified, expired, rejected
  fileName    String?
  fileUrl     String?
  fileSize    Int?
  uploadedAt  DateTime?
  expiryDate  DateTime?
  verifiedAt  DateTime?
  verifiedBy  String?
  notes       String?

  // Relation
  pilgrimId   String
  pilgrim     Pilgrim   @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([pilgrimId])
  @@map("pilgrim_documents")
}

model PaymentRecord {
  id          String   @id @default(uuid())
  amount      Float
  type        String   // dp, installment, full, refund
  method      String   // transfer, cash, card
  date        DateTime
  notes       String?
  receiptUrl  String?

  // Relation
  pilgrimId   String
  pilgrim     Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([pilgrimId])
  @@map("payment_records")
}

model Package {
  id                  String   @id @default(uuid())

  // Basic Info
  name                String
  slug                String
  category            String   // regular, plus, vip, ramadhan, budget
  description         String
  duration            Int      // days
  airline             String

  // Itinerary (JSON)
  itinerary           Json     @default("[]") // ItineraryDay[]

  // Pricing (JSON)
  hpp                 Json     // PricingBreakdown
  totalHpp            Float    @default(0)
  margin              Float    @default(0) // percentage
  marginAmount        Float    @default(0)
  publishedPrice      Float    @default(0)

  // Hotels
  makkahHotel         String
  makkahHotelRating   Int
  makkahHotelDistance  String
  madinahHotel        String
  madinahHotelRating  Int
  madinahHotelDistance String

  // Inclusions / Exclusions (string arrays)
  inclusions          String[] @default([])
  exclusions          String[] @default([])

  // Gallery
  galleryUrls         String[] @default([])

  // Status
  isActive            Boolean  @default(true)
  isPromo             Boolean  @default(false)
  promoPrice          Float?
  promoEndDate        DateTime?

  // Media
  thumbnailUrl        String?
  brochureUrl         String?

  // Soft delete
  deletedAt           DateTime?

  // Multi-tenant
  agencyId            String
  agency              Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([agencyId])
  @@index([deletedAt])
  @@unique([slug, agencyId])
  @@map("packages")
}

model Trip {
  id                    String   @id @default(uuid())
  name                  String
  packageId             String?
  departureDate         DateTime?
  returnDate            DateTime?
  registrationCloseDate DateTime?

  // Capacity
  capacity              Int      @default(0)
  registeredCount       Int      @default(0)
  confirmedCount        Int      @default(0)

  // Status
  status                String   @default("open") // open, preparing, ready, departed, completed, cancelled

  // JSON fields
  flightInfo            Json?
  checklist             Json?

  // Guide
  muthawwifName         String?
  muthawwifPhone        String?

  // Sharing
  shareCode             String?  @unique

  // Soft delete
  deletedAt             DateTime?

  // Multi-tenant
  agencyId              String
  agency                Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // Relations
  waitingList           WaitingList[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([agencyId])
  @@index([deletedAt])
  @@map("trips")
}

model ActivityLog {
  id          String   @id @default(uuid())
  type        String   // pilgrim, package, trip, payment, document
  action      String   // created, updated, deleted, uploaded, paid
  title       String
  description String
  metadata    Json?

  userId      String
  user        User     @relation(fields: [userId], references: [id])
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id])

  createdAt   DateTime @default(now())

  @@index([agencyId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model ManasikLesson {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String   // persiapan, ihram, tawaf, sai, tahallul, sunnah
  order       Int
  duration    Int      // minutes
  videoUrl    String?
  content     String   // Rich text / markdown
  tips        String[] @default([])
  isImportant Boolean  @default(false)
  emoji       String   @default("📖")

  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  progress    PilgrimManasikProgress[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agencyId])
  @@map("manasik_lessons")
}

model DoaPrayer {
  id          String   @id @default(uuid())
  title       String
  category    String   // umrah, harian, perjalanan, masjid, munajat
  arabic      String
  latin       String
  translation String
  occasion    String
  source      String
  emoji       String   @default("🤲")
  order       Int      @default(0)

  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  favorites   PilgrimDoaFavorite[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agencyId])
  @@map("doa_prayers")
}

model PilgrimManasikProgress {
  id          String   @id @default(uuid())
  pilgrimId   String
  pilgrim     Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      ManasikLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([pilgrimId, lessonId])
  @@map("pilgrim_manasik_progress")
}

model PilgrimDoaFavorite {
  id        String   @id @default(uuid())
  pilgrimId String
  pilgrim   Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  doaId     String
  doa       DoaPrayer @relation(fields: [doaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([pilgrimId, doaId])
  @@map("pilgrim_doa_favorites")
}

model NotificationPreference {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("notification_preferences")
}

// === GAMIFIKASI ===

model PointEvent {
  id          String   @id @default(uuid())
  type        String   // pilgrim, package, trip, payment, document
  action      String   // created, updated, deleted, uploaded, paid, completed, departed, lunas
  points      Int
  description String

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([userId, agencyId])
  @@map("point_events")
}

model UserBadge {
  id          String   @id @default(uuid())
  badgeKey    String
  unlockedAt  DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@map("user_badges")
}

model AgencyLeaderboard {
  id            String @id @default(uuid())
  agencyId      String
  agency        Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  totalPoints   Int    @default(0)
  pilgrimCount  Int    @default(0)
  level         Int    @default(1)
  month         Int
  year          Int

  @@unique([agencyId, month, year])
  @@map("agency_leaderboard")
}

// === COMMAND CENTER ===

model SystemAdmin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // bcrypt hashed
  role      String   @default("super_admin")
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_admins")
}

// === BLOCKCHAIN CERTIFICATES ===

model BlockchainCertificate {
  id                String    @id @default(uuid())
  certificateNumber String    @unique
  txHash            String    // simulated 0x... hash
  blockNumber       Int       // simulated block number
  metadata          Json?
  status            String    @default("pending") // pending, verified, revoked

  pilgrimId         String
  pilgrim           Pilgrim   @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  agencyId          String
  agency            Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  issuedAt          DateTime  @default(now())
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([agencyId])
  @@index([pilgrimId])
  @@map("blockchain_certificates")
}

// === ACADEMY LMS ===

model AcademyCourse {
  id             String    @id @default(uuid())
  title          String
  description    String
  category       String    // operasional, manasik, bisnis, tutorial
  level          String    // pemula, menengah, lanjutan
  thumbnailUrl   String?
  duration       String    // e.g. "6 jam"
  instructorName String
  totalLessons   Int       @default(0)
  isPublished    Boolean   @default(true)
  order          Int       @default(0)

  lessons        AcademyLesson[]
  progress       AcademyCourseProgress[]
  quiz           AcademyQuiz?
  reviews        AcademyCourseReview[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("academy_courses")
}

model AcademyLesson {
  id        String  @id @default(uuid())
  courseId   String
  course     AcademyCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title      String
  content    String  // markdown/text
  videoUrl   String?
  order      Int     @default(0)
  duration   String? // e.g. "30 menit"

  createdAt  DateTime @default(now())

  @@index([courseId])
  @@map("academy_lessons")
}

model AcademyCourseProgress {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId          String
  course           AcademyCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completedLessons Int       @default(0)
  completedLessonIds String[] @default([])
  totalLessons     Int       @default(0)
  status           String    @default("not_started") // not_started, in_progress, completed

  startedAt        DateTime?
  completedAt      DateTime?

  @@unique([userId, courseId])
  @@map("academy_course_progress")
}

// === PILGRIM GAMIFICATION ===

model PilgrimPointEvent {
  id          String   @id @default(uuid())
  pilgrimId   String
  pilgrim     Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  action      String   // complete_lesson, complete_course, daily_login, update_profile, upload_document, favorite_doa
  points      Int
  description String
  metadata    Json?

  createdAt   DateTime @default(now())

  @@index([pilgrimId])
  @@index([pilgrimId, action])
  @@map("pilgrim_point_events")
}

model PilgrimBadge {
  id               String   @id @default(uuid())
  pilgrimId        String
  pilgrim          Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  badgeKey         String
  badgeName        String
  badgeDescription String
  badgeIcon        String

  earnedAt         DateTime @default(now())

  @@unique([pilgrimId, badgeKey])
  @@map("pilgrim_badges")
}

// === LOGIN HISTORY ===

model LoginHistory {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress    String?
  userAgent    String?
  sessionToken String?
  isActive     Boolean   @default(true)
  loginAt      DateTime  @default(now())
  logoutAt     DateTime?

  @@index([userId])
  @@map("login_history")
}

// === SESSION 10: NEW MODELS ===

// Pilgrim Notes (internal notes per pilgrim)
model PilgrimNote {
  id          String   @id @default(uuid())
  content     String
  pilgrimId   String
  pilgrim     Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  authorId    String
  authorName  String
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([pilgrimId])
  @@index([agencyId])
  @@map("pilgrim_notes")
}

// Agency Task Management
model AgencyTask {
  id           String    @id @default(uuid())
  title        String
  description  String?
  status       String    @default("todo") // todo, in_progress, done
  priority     String    @default("medium") // low, medium, high
  dueDate      DateTime?
  assignedTo   String?
  assigneeName String?
  createdBy    String
  agencyId     String
  agency       Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([agencyId])
  @@map("agency_tasks")
}

// Email Templates
model EmailTemplate {
  id        String   @id @default(uuid())
  event     String   // welcome, payment_reminder, departure_reminder
  subject   String
  bodyHtml  String
  isActive  Boolean  @default(true)
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([event, agencyId])
  @@map("email_templates")
}

// Waiting List for full trips
model WaitingList {
  id           String    @id @default(uuid())
  tripId       String
  trip         Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  pilgrimName  String
  phone        String
  email        String?
  notes        String?
  notified     Boolean   @default(false)
  notifiedAt   DateTime?
  agencyId     String
  agency       Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt    DateTime  @default(now())

  @@index([tripId])
  @@index([agencyId])
  @@map("waiting_list")
}

// Pilgrim Photos / Gallery
model PilgrimPhoto {
  id          String   @id @default(uuid())
  pilgrimId   String
  pilgrim     Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  tripId      String?
  url         String
  caption     String?
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  uploadedAt  DateTime @default(now())

  @@index([pilgrimId])
  @@index([agencyId])
  @@map("pilgrim_photos")
}

// Pilgrim Testimonials / Reviews
model PilgrimTestimonial {
  id          String   @id @default(uuid())
  pilgrimId   String
  pilgrim     Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  rating      Int      // 1-5
  comment     String
  tripId      String?
  isPublic    Boolean  @default(true)
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([pilgrimId, tripId])
  @@map("pilgrim_testimonials")
}

// Referral System
model Referral {
  id                String   @id @default(uuid())
  referralCode      String   @unique
  pilgrimId         String
  pilgrim           Pilgrim  @relation("referrer", fields: [pilgrimId], references: [id], onDelete: Cascade)
  referredPilgrimId String?  @unique
  referredPilgrim   Pilgrim? @relation("referred", fields: [referredPilgrimId], references: [id], onDelete: SetNull)
  bonusPoints       Int      @default(50)
  status            String   @default("pending") // pending, completed
  agencyId          String
  agency            Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())

  @@index([pilgrimId])
  @@index([agencyId])
  @@map("referrals")
}

// Notification Center
model Notification {
  id        String    @id @default(uuid())
  title     String
  body      String
  type      String    // task, payment, pilgrim, trip, system
  isRead    Boolean   @default(false)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agencyId  String
  agency    Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  metadata  Json?
  readAt    DateTime?

  createdAt DateTime  @default(now())

  @@index([userId, isRead])
  @@index([agencyId])
  @@map("notifications")
}

// Scheduled Reports
model ScheduledReport {
  id          String    @id @default(uuid())
  frequency   String    // weekly, monthly
  reportType  String    // financial, pilgrim, trip
  dayOfWeek   Int?      // 0-6 for weekly
  dayOfMonth  Int?      // 1-31 for monthly
  emailTo     String
  isActive    Boolean   @default(true)
  lastSentAt  DateTime?
  agencyId    String
  agency      Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive, agencyId])
  @@map("scheduled_reports")
}

// Academy Quiz
model AcademyQuiz {
  id         String    @id @default(uuid())
  courseId    String    @unique
  course     AcademyCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title      String
  passScore  Int       @default(70)

  questions  AcademyQuizQuestion[]
  attempts   AcademyQuizAttempt[]

  createdAt  DateTime  @default(now())

  @@map("academy_quizzes")
}

model AcademyQuizQuestion {
  id           String   @id @default(uuid())
  quizId       String
  quiz         AcademyQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question     String
  options      String[]
  correctIndex Int
  order        Int      @default(0)

  @@index([quizId])
  @@map("academy_quiz_questions")
}

model AcademyQuizAttempt {
  id          String   @id @default(uuid())
  quizId      String
  quiz        AcademyQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers     Json
  score       Int
  passed      Boolean

  attemptedAt DateTime @default(now())

  @@index([quizId])
  @@index([userId])
  @@map("academy_quiz_attempts")
}

// Academy Course Reviews
model AcademyCourseReview {
  id        String   @id @default(uuid())
  courseId   String
  course    AcademyCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5
  comment   String?

  createdAt DateTime @default(now())

  @@unique([courseId, userId])
  @@map("academy_course_reviews")
}

// Roommate Matching Preferences
model RoommatePreference {
  id             String   @id @default(uuid())
  pilgrimId      String   @unique
  pilgrim        Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  gender         String
  ageRange       String   // e.g. "20-30", "30-40"
  smokingPref    String   // no_smoking, doesn't_matter
  snoringPref    String   // no_snoring, doesn't_matter
  languagePref   String   // indonesia, arabic, english
  notes          String?
  matchedWith    String?
  tripId         String?
  agencyId       String
  agency         Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([agencyId])
  @@map("roommate_preferences")
}

// === SESSION 17: MARKETPLACE, FORUM, NEWS, TRADE CENTRE ===

// Marketplace Item (Global — managed by Command Center)
model MarketplaceItem {
  id            String   @id @default(uuid())
  name          String
  vendor        String
  category      String   // hotel, visa, transport, asuransi, mutawwif, tiket
  description   String
  emoji         String   @default("📦")
  badge         String?  // Best Seller, Premium, Popular, New
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  tags          String[] @default([])
  details       Json     @default("{}")
  price         String
  priceAmount   Float    @default(0)
  priceUnit     String
  city          String?
  isActive      Boolean  @default(true)
  createdBy     String?  // systemAdmin id

  reviews       MarketplaceReview[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("marketplace_items")
}

// Marketplace Review (Global — any agency user can review)
model MarketplaceReview {
  id          String   @id @default(uuid())
  itemId      String
  item        MarketplaceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId      String
  userName    String
  agencyName  String
  rating      Int      // 1-5
  comment     String

  createdAt   DateTime @default(now())

  @@index([itemId])
  @@unique([itemId, userId])
  @@map("marketplace_reviews")
}

// Forum Thread (Global — all agency users)
model ForumThread {
  id            String   @id @default(uuid())
  title         String
  content       String
  excerpt       String
  category      String   // review, regulasi, operasional, sharing, scam, tanya
  tags          String[] @default([])
  authorId      String
  authorName    String
  authorAvatar  String   @default("")
  authorBadge   String?  // Admin, Moderator, Verified, Top Contributor
  agencyName    String?
  replyCount    Int      @default(0)
  viewCount     Int      @default(0)
  isPinned      Boolean  @default(false)
  isHot         Boolean  @default(false)
  isSolved      Boolean  @default(false)
  isLocked      Boolean  @default(false)
  lastReplyBy   String?
  lastReplyAt   DateTime?

  // Soft delete
  deletedAt     DateTime?

  replies       ForumReply[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([isPinned])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("forum_threads")
}

// Forum Reply
model ForumReply {
  id            String   @id @default(uuid())
  threadId      String
  thread        ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  content       String
  authorId      String
  authorName    String
  authorAvatar  String   @default("")
  authorBadge   String?
  likes         Int      @default(0)

  createdAt     DateTime @default(now())

  @@index([threadId])
  @@map("forum_replies")
}

// News Article (Global — managed by Command Center)
model NewsArticle {
  id            String    @id @default(uuid())
  title         String
  excerpt       String
  content       String
  category      String    // regulasi, pengumuman, event, tips, peringatan
  emoji         String    @default("📰")
  tags          String[]  @default([])
  author        String
  authorRole    String
  createdBy     String?   // systemAdmin id
  readTime      Int       @default(5)
  isBreaking    Boolean   @default(false)
  isOfficial    Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isPublished])
  @@index([category])
  @@index([publishedAt])
  @@map("news_articles")
}

// Trade Product (Hybrid — agency submits, CC curates)
model TradeProduct {
  id              String    @id @default(uuid())
  name            String
  producer        String
  origin          String
  category        String    // makanan, buah, fashion, kosmetik, kerajinan, ibadah
  description     String
  emoji           String    @default("📦")
  certifications  String[]  @default([])
  rating          Float     @default(0)
  inquiryCount    Int       @default(0)
  moq             String
  targetMarkets   String[]  @default([])
  price           String
  status          String    @default("pending") // pending, active, rejected
  rejectionReason String?
  agencyId        String
  agency          Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  submittedBy     String
  submitterName   String
  curatedBy       String?
  curatedAt       DateTime?

  inquiries       TradeInquiry[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([agencyId])
  @@index([status])
  @@index([category])
  @@map("trade_products")
}

// Trade Inquiry
model TradeInquiry {
  id          String   @id @default(uuid())
  productId   String
  product     TradeProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  userId      String
  userName    String
  message     String
  status      String   @default("pending") // pending, responded, closed

  createdAt   DateTime @default(now())

  @@index([productId])
  @@index([agencyId])
  @@map("trade_inquiries")
}

// === SESSION 18: FINANCIAL FEATURES ===

// GezmaPay Wallet
model GezmaPayWallet {
  id            String   @id @default(uuid())
  agencyId      String
  agency        Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  balance       Float    @default(0)
  currency      String   @default("IDR")
  isActive      Boolean  @default(true)

  transactions  GezmaPayTransaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([agencyId])
  @@map("gezmapay_wallets")
}

// GezmaPay Transaction
model GezmaPayTransaction {
  id            String   @id @default(uuid())
  walletId      String
  wallet        GezmaPayWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          String   // topup, payment, refund, transfer
  amount        Float
  description   String
  reference     String?
  status        String   @default("completed") // pending, completed, failed
  balanceAfter  Float    @default(0)

  createdAt     DateTime @default(now())

  @@index([walletId])
  @@index([createdAt])
  @@map("gezmapay_transactions")
}

// Tabungan Umrah (Umrah Savings)
model UmrahSavings {
  id            String   @id @default(uuid())
  agencyId      String
  agency        Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  pilgrimName   String
  targetAmount  Float
  currentAmount Float    @default(0)
  targetDate    DateTime
  packageName   String?
  status        String   @default("active") // active, completed, cancelled

  deposits      UmrahSavingsDeposit[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([agencyId])
  @@map("umrah_savings")
}

// Tabungan Umrah Deposit
model UmrahSavingsDeposit {
  id          String   @id @default(uuid())
  savingsId   String
  savings     UmrahSavings @relation(fields: [savingsId], references: [id], onDelete: Cascade)
  amount      Float
  method      String   // transfer, cash, auto_debit
  notes       String?
  balanceAfter Float   @default(0)

  createdAt   DateTime @default(now())

  @@index([savingsId])
  @@map("umrah_savings_deposits")
}

// PayLater Syariah Application
model PayLaterApplication {
  id              String   @id @default(uuid())
  agencyId        String
  agency          Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  pilgrimName     String
  pilgrimPhone    String
  totalAmount     Float
  tenorMonths     Int      // 3, 6, 12
  monthlyAmount   Float
  akadType        String   @default("murabahah") // murabahah, ijarah
  marginRate      Float    @default(0) // percentage
  status          String   @default("pending") // pending, approved, rejected, active, completed
  notes           String?

  installments    PayLaterInstallment[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([agencyId])
  @@index([status])
  @@map("paylater_applications")
}

// PayLater Installment
model PayLaterInstallment {
  id              String    @id @default(uuid())
  applicationId   String
  application     PayLaterApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  installmentNo   Int
  amount          Float
  dueDate         DateTime
  paidAt          DateTime?
  status          String    @default("pending") // pending, paid, overdue

  createdAt       DateTime  @default(now())

  @@index([applicationId])
  @@map("paylater_installments")
}

// === SESSION 19: SERVICES & DOCUMENTS ===

// Platform Service (managed by Command Center)
model PlatformService {
  id          String   @id @default(uuid())
  title       String
  description String
  emoji       String   @default("\u{1F4E6}")
  color       String   @default("#2563EB")
  category    String   // legal, visa, dokumen, support, asuransi, komunitas
  features    String[] @default([])
  ctaText     String
  ctaLink     String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([order])
  @@map("platform_services")
}

// Platform Document (downloadable files)
model PlatformDocument {
  id            String   @id @default(uuid())
  name          String
  description   String?
  format        String   // PDF, XLSX, DOCX
  fileSize      String
  fileUrl       String?
  category      String   @default("general") // general, template, sop, checklist
  downloadCount Int      @default(0)
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@map("platform_documents")
}
