generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Agency {
  id              String   @id @default(uuid())
  name            String   // Company brand name
  legalName       String   // PT. ...
  tagline         String?
  description     String?

  // PPIU Info
  ppiuNumber      String?  @unique
  ppiuIssueDate   DateTime?
  ppiuExpiryDate  DateTime?
  ppiuStatus      String   @default("pending") // pending, active, expiring, expired

  // Contact
  email           String   @unique
  phone           String
  whatsapp        String?
  website         String?

  // Address
  address         String?
  city            String?
  province        String?
  postalCode      String?

  // Branding
  primaryColor    String   @default("#F60000")
  logoUrl         String?

  // Verification
  verificationCode String  @unique @default(uuid())
  isVerified       Boolean @default(false)

  // Settings
  currency        String   @default("IDR")
  timezone        String   @default("Asia/Jakarta")

  // White-label Branding
  secondaryColor  String?
  faviconUrl      String?
  logoLightUrl    String?
  logoDarkUrl     String?
  appTitle        String?

  // Gamification
  totalPoints     Int      @default(0)

  // Relations
  users           User[]
  pilgrims        Pilgrim[]
  packages        Package[]
  trips           Trip[]
  activityLogs    ActivityLog[]
  manasikLessons  ManasikLesson[]
  doaPrayers      DoaPrayer[]
  leaderboard     AgencyLeaderboard[]
  pointEvents     PointEvent[]
  certificates    BlockchainCertificate[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("agencies")
}

model User {
  id              String   @id @default(uuid())

  // Personal Info
  name            String
  email           String   @unique
  password        String   // bcrypt hashed
  phone           String?
  position        String?  // e.g., "Direktur", "Admin Operasional"
  avatarUrl       String?

  // Role
  role            String   @default("admin") // owner, admin, staff, marketing

  // Granular Permissions (JSON override per-user)
  permissions     Json?

  // Status
  isActive        Boolean  @default(true)
  isVerified      Boolean  @default(false)
  verificationCode String? @unique
  verificationExpiry DateTime?

  // Gamification
  totalPoints     Int      @default(0)
  level           Int      @default(1)

  // Agency relation
  agencyId        String
  agency          Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // Session tracking
  lastLoginAt     DateTime?

  // Relations
  activityLogs    ActivityLog[]
  notificationPrefs NotificationPreference?
  pointEvents     PointEvent[]
  badges          UserBadge[]
  courseProgress   AcademyCourseProgress[]
  loginHistory    LoginHistory[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("users")
}

model Pilgrim {
  id                String   @id @default(uuid())

  // Personal Info
  nik               String
  name              String
  gender            String   // male, female
  birthPlace        String
  birthDate         String   // ISO date string
  address           String
  city              String
  province          String
  postalCode        String?

  // Contact
  phone             String
  email             String
  whatsapp          String?

  // Emergency Contact (JSON)
  emergencyContact  Json     // { name, phone, relation }

  // Checklist (JSON)
  checklist         Json     @default("{}")

  // Booking
  bookingCode       String?

  // Verification
  verificationCode  String?  @unique

  // Status & Assignment
  status            String   @default("lead") // lead, dp, lunas, dokumen, visa, ready, departed, completed
  tripId            String?
  roomNumber        String?
  roomType          String?  // single, double, triple, quad

  // Cached payment totals
  totalPaid         Float    @default(0)
  remainingBalance  Float    @default(0)

  // Notes
  notes             String?

  // Metadata
  createdBy         String?

  // Multi-tenant
  agencyId          String
  agency            Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // Relations
  documents         PilgrimDocument[]
  payments          PaymentRecord[]
  manasikProgress   PilgrimManasikProgress[]
  doaFavorites      PilgrimDoaFavorite[]
  certificates      BlockchainCertificate[]
  pointEvents       PilgrimPointEvent[]
  badges            PilgrimBadge[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([nik, agencyId])
  @@unique([agencyId, bookingCode])
  @@map("pilgrims")
}

model PilgrimDocument {
  id          String    @id @default(uuid())
  type        String    // ktp, passport, photo, visa, health_cert, book_nikah
  status      String    @default("missing") // missing, uploaded, verified, expired, rejected
  fileName    String?
  fileUrl     String?
  fileSize    Int?
  uploadedAt  DateTime?
  expiryDate  DateTime?
  verifiedAt  DateTime?
  verifiedBy  String?
  notes       String?

  // Relation
  pilgrimId   String
  pilgrim     Pilgrim   @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("pilgrim_documents")
}

model PaymentRecord {
  id          String   @id @default(uuid())
  amount      Float
  type        String   // dp, installment, full, refund
  method      String   // transfer, cash, card
  date        DateTime
  notes       String?
  receiptUrl  String?

  // Relation
  pilgrimId   String
  pilgrim     Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("payment_records")
}

model Package {
  id                  String   @id @default(uuid())

  // Basic Info
  name                String
  slug                String
  category            String   // regular, plus, vip, ramadhan, budget
  description         String
  duration            Int      // days
  airline             String

  // Itinerary (JSON)
  itinerary           Json     @default("[]") // ItineraryDay[]

  // Pricing (JSON)
  hpp                 Json     // PricingBreakdown
  totalHpp            Float    @default(0)
  margin              Float    @default(0) // percentage
  marginAmount        Float    @default(0)
  publishedPrice      Float    @default(0)

  // Hotels
  makkahHotel         String
  makkahHotelRating   Int
  makkahHotelDistance  String
  madinahHotel        String
  madinahHotelRating  Int
  madinahHotelDistance String

  // Inclusions / Exclusions (string arrays)
  inclusions          String[] @default([])
  exclusions          String[] @default([])

  // Gallery
  galleryUrls         String[] @default([])

  // Status
  isActive            Boolean  @default(true)
  isPromo             Boolean  @default(false)
  promoPrice          Float?
  promoEndDate        DateTime?

  // Media
  thumbnailUrl        String?
  brochureUrl         String?

  // Multi-tenant
  agencyId            String
  agency              Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([slug, agencyId])
  @@map("packages")
}

model Trip {
  id                    String   @id @default(uuid())
  name                  String
  packageId             String?
  departureDate         DateTime?
  returnDate            DateTime?
  registrationCloseDate DateTime?

  // Capacity
  capacity              Int      @default(0)
  registeredCount       Int      @default(0)
  confirmedCount        Int      @default(0)

  // Status
  status                String   @default("open") // open, preparing, ready, departed, completed, cancelled

  // JSON fields
  flightInfo            Json?
  checklist             Json?

  // Guide
  muthawwifName         String?
  muthawwifPhone        String?

  // Multi-tenant
  agencyId              String
  agency                Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("trips")
}

model ActivityLog {
  id          String   @id @default(uuid())
  type        String   // pilgrim, package, trip, payment, document
  action      String   // created, updated, deleted, uploaded, paid
  title       String
  description String
  metadata    Json?

  userId      String
  user        User     @relation(fields: [userId], references: [id])
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id])

  createdAt   DateTime @default(now())

  @@map("activity_logs")
}

model ManasikLesson {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String   // persiapan, ihram, tawaf, sai, tahallul, sunnah
  order       Int
  duration    Int      // minutes
  videoUrl    String?
  content     String   // Rich text / markdown
  tips        String[] @default([])
  isImportant Boolean  @default(false)
  emoji       String   @default("📖")

  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  progress    PilgrimManasikProgress[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("manasik_lessons")
}

model DoaPrayer {
  id          String   @id @default(uuid())
  title       String
  category    String   // umrah, harian, perjalanan, masjid, munajat
  arabic      String
  latin       String
  translation String
  occasion    String
  source      String
  emoji       String   @default("🤲")
  order       Int      @default(0)

  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  favorites   PilgrimDoaFavorite[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("doa_prayers")
}

model PilgrimManasikProgress {
  id          String   @id @default(uuid())
  pilgrimId   String
  pilgrim     Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      ManasikLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([pilgrimId, lessonId])
  @@map("pilgrim_manasik_progress")
}

model PilgrimDoaFavorite {
  id        String   @id @default(uuid())
  pilgrimId String
  pilgrim   Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  doaId     String
  doa       DoaPrayer @relation(fields: [doaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([pilgrimId, doaId])
  @@map("pilgrim_doa_favorites")
}

model NotificationPreference {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("notification_preferences")
}

// === GAMIFIKASI ===

model PointEvent {
  id          String   @id @default(uuid())
  type        String   // pilgrim, package, trip, payment, document
  action      String   // created, updated, deleted, uploaded, paid, completed, departed, lunas
  points      Int
  description String

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@map("point_events")
}

model UserBadge {
  id          String   @id @default(uuid())
  badgeKey    String
  unlockedAt  DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@map("user_badges")
}

model AgencyLeaderboard {
  id            String @id @default(uuid())
  agencyId      String
  agency        Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  totalPoints   Int    @default(0)
  pilgrimCount  Int    @default(0)
  level         Int    @default(1)
  month         Int
  year          Int

  @@unique([agencyId, month, year])
  @@map("agency_leaderboard")
}

// === COMMAND CENTER ===

model SystemAdmin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // bcrypt hashed
  role      String   @default("super_admin")
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_admins")
}

// === BLOCKCHAIN CERTIFICATES ===

model BlockchainCertificate {
  id                String    @id @default(uuid())
  certificateNumber String    @unique
  txHash            String    // simulated 0x... hash
  blockNumber       Int       // simulated block number
  metadata          Json?
  status            String    @default("pending") // pending, verified, revoked

  pilgrimId         String
  pilgrim           Pilgrim   @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  agencyId          String
  agency            Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  issuedAt          DateTime  @default(now())
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("blockchain_certificates")
}

// === ACADEMY LMS ===

model AcademyCourse {
  id             String    @id @default(uuid())
  title          String
  description    String
  category       String    // operasional, manasik, bisnis, tutorial
  level          String    // pemula, menengah, lanjutan
  thumbnailUrl   String?
  duration       String    // e.g. "6 jam"
  instructorName String
  totalLessons   Int       @default(0)
  isPublished    Boolean   @default(true)
  order          Int       @default(0)

  lessons        AcademyLesson[]
  progress       AcademyCourseProgress[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("academy_courses")
}

model AcademyLesson {
  id        String  @id @default(uuid())
  courseId   String
  course     AcademyCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title      String
  content    String  // markdown/text
  videoUrl   String?
  order      Int     @default(0)
  duration   String? // e.g. "30 menit"

  createdAt  DateTime @default(now())

  @@map("academy_lessons")
}

model AcademyCourseProgress {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId          String
  course           AcademyCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completedLessons Int       @default(0)
  completedLessonIds String[] @default([])
  totalLessons     Int       @default(0)
  status           String    @default("not_started") // not_started, in_progress, completed

  startedAt        DateTime?
  completedAt      DateTime?

  @@unique([userId, courseId])
  @@map("academy_course_progress")
}

// === PILGRIM GAMIFICATION ===

model PilgrimPointEvent {
  id          String   @id @default(uuid())
  pilgrimId   String
  pilgrim     Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  action      String   // complete_lesson, complete_course, daily_login, update_profile, upload_document, favorite_doa
  points      Int
  description String
  metadata    Json?

  createdAt   DateTime @default(now())

  @@map("pilgrim_point_events")
}

model PilgrimBadge {
  id               String   @id @default(uuid())
  pilgrimId        String
  pilgrim          Pilgrim  @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  badgeKey         String
  badgeName        String
  badgeDescription String
  badgeIcon        String

  earnedAt         DateTime @default(now())

  @@unique([pilgrimId, badgeKey])
  @@map("pilgrim_badges")
}

// === LOGIN HISTORY ===

model LoginHistory {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress  String?
  userAgent  String?
  loginAt    DateTime  @default(now())
  logoutAt   DateTime?

  @@map("login_history")
}
